{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kichijitsu",
  "version": "0.1.6",
  "identifier": "cc.love-rox.kichijitsu",
  "build": {
    "frontendDist": "https://kichijitsu.love-rox.cc/app"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "kichijitsu",
        "url": "https://kichijitsu.love-rox.cc/app",
        "width": 1200,
        "height": 800,
        "minWidth": 480,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
