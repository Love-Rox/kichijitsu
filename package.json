{
  "name": "kichijitsu",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "lint": "pnpm --filter web lint",
    "deploy:sync": "pnpm --filter sync exec wrangler deploy",
    "deploy:web": "pnpm --filter sync exec wrangler deploy --config ../web/wrangler.jsonc"
  }
}
